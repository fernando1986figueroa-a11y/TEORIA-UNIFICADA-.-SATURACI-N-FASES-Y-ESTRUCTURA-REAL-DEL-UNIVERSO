// ── mini gráficas inline ────────────────────────────────────────────────
function MiniChart({data, step, color, label, yKey}){
  const W=220, H=80, pad=20;
  const vals=data.map(d=>d[yKey]);
  const mn=Math.min(...vals), mx=Math.max(...vals)+1e-6;
  const toX=i=>pad+(i/data.length)*(W-2*pad);
  const toY=v=>H-pad-(v-mn)/(mx-mn)*(H-2*pad);
  const pts=vals.map((v,i)=>`${toX(i)},${toY(v)}`).join(' ');
  const cx=toX(step), cy=toY(vals[step]);
  return(
    <svg width={W} height={H} style={{display:'block'}}>
      <polyline points={pts} fill="none" stroke={`${color}55`} strokeWidth={1.5}/>
      <polyline points={vals.slice(0,step+1).map((v,i)=>`${toX(i)},${toY(v)}`).join(' ')} fill="none" stroke={color} strokeWidth={2}/>
      <circle cx={cx} cy={cy} r={4} fill={color}/>
      <text x={4} y={12} fill={`${color}99`} fontSize={9} fontFamily={MONO}>{label}: {vals[step]?.toFixed(3)}</text>
    </svg>
  );
}

